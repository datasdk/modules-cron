{
    "name": "datasdk/cron-module",
    "type": "laravel-module",
    "license": "proprietary",

    "description": "Cron / scheduler module",

    "require": {
        "studio/laravel-totem": "^11.1"
    },
    "authors": [
        {
            "name": "Kasper L. Kristiansen",
            "email": "info@datas.dk"
        }
    ],
    "extra": {
        "laravel": {
            "dont-discover": [],
            "providers": [],
            "aliases": {}
        }
